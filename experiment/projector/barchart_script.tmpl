        const xAxisData = {{.XAxisDataJSON}};
        const seriesData = {{.SeriesJSON}};
        const chart = echarts.init(document.getElementById('chart'), null, { renderer: 'svg' });
        
        const option = {
            backgroundColor: 'transparent',
            animation: false,
            tooltip: { trigger: 'axis' },
            legend: { top: '5%', textStyle: { color: '#475569', fontSize: 12 } },
            grid: { left: '10%', right: '10%', top: '20%', bottom: '15%' },
            xAxis: {
                type: 'category',
                data: xAxisData,
                axisLabel: { color: '#475569' },
                nameLocation: 'middle',
                nameGap: 30
            },
            yAxis: {
                type: 'value',
                axisLabel: { color: '#475569' },
                splitLine: { show: true, lineStyle: { color: '#e2e8f0', type: 'dashed' } }
            },
            series: seriesData.map(s => ({
                name: s.name,
                type: 'bar',
                data: s.data,
                itemStyle: { borderRadius: [4, 4, 0, 0] }
            }))
        };
        chart.setOption(option);
