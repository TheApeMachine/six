        const xAxisData = {{.XAxisDataJSON}};
        const seriesData = {{.SeriesJSON}};
        const yMin = {{.YMin}};
        const yMax = {{.YMax}};
        const chart = echarts.init(document.getElementById('chart'), null, { renderer: 'svg' });

        const palette = ['#3b82f6','#22c55e','#94a3b8','#ef4444','#a855f7','#f59e0b','#06b6d4','#ec4899'];

        const series = seriesData.map((s, i) => {
            const color = palette[i % palette.length];
            const base = {
                name: s.name,
                data: s.data,
                itemStyle: { color },
                lineStyle: { color }
            };
            if (s.type === 'bar') {
                return { ...base, type: 'bar', barWidth: s.barWidth || '15%', itemStyle: { color, borderRadius: [4, 4, 0, 0] } };
            } else if (s.type === 'dashed') {
                return { ...base, type: 'line', smooth: false, symbol: s.symbol || 'diamond', symbolSize: 6,
                         lineStyle: { color, type: 'dashed', width: 1.5 } };
            } else {
                // default: smooth line
                return { ...base, type: 'line', smooth: true, symbol: s.symbol || 'circle', symbolSize: 4,
                         lineStyle: { color, width: 2 } };
            }
        });

        const option = {
            backgroundColor: 'transparent',
            animation: false,
            tooltip: { trigger: 'axis' },
            legend: {
                top: '3%',
                selectedMode: false,
                textStyle: { color: '#475569', fontSize: 11 }
            },
            grid: { left: '10%', right: '10%', top: '18%', bottom: '15%' },
            xAxis: {
                type: 'category',
                data: xAxisData,
                axisLabel: { color: '#475569' },
                name: '{{.XAxisName}}',
                nameLocation: 'middle',
                nameGap: 25,
                nameTextStyle: { color: '#475569' }
            },
            yAxis: {
                type: 'value',
                min: yMin,
                max: yMax,
                axisLabel: { color: '#475569' },
                splitLine: { show: true, lineStyle: { color: '#e2e8f0', type: 'dashed' } },
                name: '{{.YAxisName}}',
                nameLocation: 'middle',
                nameGap: 35,
                nameTextStyle: { color: '#475569' }
            },
            series
        };
        chart.setOption(option);
