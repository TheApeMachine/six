        const labels = {{.LabelsJSON}};
        const matrix = {{.MatrixJSON}};
        const accuracy = {{.Accuracy}};
        const macroF1 = {{.MacroF1}};
        const resonance = {{.Resonance}};
        const chart = echarts.init(document.getElementById('chart'), null, { renderer: 'svg' });

        // Build row-normalised proportions and heatmap data.
        const heatData = [];
        let totalSamples = 0;
        let classesSeen = 0;
        let recallSum = 0;

        const rowSums = labels.map((_, y) => {
            const sum = matrix[y].reduce((s, v) => s + v, 0);
            const recall = sum > 0 ? (matrix[y][y] / sum) : 0;
            recallSum += recall;
            if (sum > 0) classesSeen++;
            totalSamples += sum;
            return sum;
        });

        const balancedAcc = recallSum / labels.length;

        labels.forEach((_, y) => {
            labels.forEach((_, x) => {
                const count = matrix[y][x];
                const pct = rowSums[y] > 0 ? count / rowSums[y] : 0;
                // ECharts heatmap data: [xIdx, yIdx, value, count]
                heatData.push([x, y, pct, count]);
            });
        });

        const yLabels = [...labels].reverse();

        const option = {
            backgroundColor: 'transparent',
            animation: false,
            tooltip: {
                formatter: function (p) {
                    const d = p.data;
                    return labels[d[0]] + ' &rarr; ' + labels[labels.length - 1 - d[1]] +
                        '<br/>Count: ' + d[3] +
                        '<br/>Recall: ' + (d[2] * 100).toFixed(1) + '%';
                }
            },
            grid: { left: '12%', right: '18%', top: '10%', bottom: '15%' },
            xAxis: {
                type: 'category',
                data: labels,
                name: 'Predicted',
                nameLocation: 'middle',
                nameGap: 35,
                nameTextStyle: { fontSize: 14, color: '#1e293b' },
                axisLabel: { color: '#334155', fontSize: 12, rotate: 30 },
                splitLine: { show: false },
                axisTick: { show: false }
            },
            yAxis: {
                type: 'category',
                data: yLabels,
                name: 'True',
                nameLocation: 'middle',
                nameGap: 60,
                nameTextStyle: { fontSize: 14, color: '#1e293b' },
                axisLabel: { color: '#334155', fontSize: 12 },
                splitLine: { show: false },
                axisTick: { show: false }
            },
            visualMap: {
                min: 0,
                max: 1,
                calculable: false,
                orient: 'vertical',
                right: '3%',
                top: 'center',
                text: ['1.0', '0.0'],
                textStyle: { color: '#475569', fontSize: 11 },
                itemHeight: 200,
                inRange: {
                    color: ['#f0f4fa', '#c6d9f1', '#7ba7d7', '#3b82c4', '#1d4f91', '#0c2d57']
                }
            },
            graphic: [{
                type: 'group',
                right: 60,
                top: 20,
                children: [
                    {
                        type: 'rect',
                        z: 100,
                        shape: { width: 180, height: 95 },
                        style: {
                            fill: '#f8fafc',
                            stroke: '#cbd5e1',
                            lineWidth: 1,
                            shadowBlur: 4,
                            shadowColor: 'rgba(0,0,0,0.05)'
                        }
                    },
                    {
                        type: 'text',
                        z: 101,
                        left: 12,
                        top: 10,
                        style: {
                            text: 'Overall Accuracy: ' + (accuracy * 100).toFixed(1) + '%\n' +
                                  'Balanced Acc: ' + (balancedAcc * 100).toFixed(1) + '%\n' +
                                  'Macro-F1: ' + macroF1.toFixed(3) + '\n' +
                                  'Resonance: ' + parseFloat(resonance).toFixed(6) + '\n' +
                                  'Sample Size: N=' + totalSamples,
                            fontSize: 11,
                            fontFamily: 'monospace',
                            fill: '#1e293b',
                            lineHeight: 16
                        }
                    }
                ]
            }],
            series: [{
                name: 'Confusion Matrix',
                type: 'heatmap',
                data: heatData.map(d => {
                    return [d[0], labels.length - 1 - d[1], d[2], d[3]];
                }),
                label: {
                    show: true,
                    formatter: function (p) {
                        const count = p.data[3];
                        const pct = (p.data[2] * 100).toFixed(0);
                        // Any non-zero proportion maps to a dark blue in the
                        // colour ramp, so use white text for all non-zero cells.
                        const tag = (p.data[2] > 0) ? 'w' : 'd';
                        return '{' + tag + '|' + count + '}\n{' + tag + '|(' + pct + '%)}';
                    },
                    rich: {
                        w: { color: '#ffffff', fontSize: 13, fontWeight: 'bold', lineHeight: 18, align: 'center' },
                        d: { color: '#1e293b', fontSize: 13, fontWeight: 'bold', lineHeight: 18, align: 'center' }
                    }
                },
                itemStyle: {
                    borderColor: '#ffffff',
                    borderWidth: 2
                }
            }]
        };

        chart.setOption(option);
